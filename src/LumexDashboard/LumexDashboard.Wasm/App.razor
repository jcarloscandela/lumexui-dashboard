<LumexThemeProvider />

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(LumexDashboard.Shared._Imports).Assembly }"
        NotFoundPage="typeof(LumexDashboard.Shared.Components.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(LumexDashboard.Shared.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
